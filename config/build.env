# Build config, sourced by scripts/*.sh.

# morphe-cli is pinned (the patch format is coupled to the cli version).
MORPHE_CLI_VERSION=1.9.1
MORPHE_CLI_REPO=MorpheApp/morphe-cli

# Patch sources. anddea is my fork with the setting defaults baked in.
ANDDEA_REPO=pmaxhogan/revanced-patches
ANDDEA_CHANNEL=release
MORPHE_PATCHES_REPO=MorpheApp/morphe-patches
MORPHE_CHANNEL=release

YT_PACKAGE=com.google.android.youtube
MUSIC_PACKAGE=com.google.android.apps.youtube.music

# Empty = newest patch-compatible version (morphe-cli list-versions). Set to pin.
YT_VERSION_PIN=
MUSIC_VERSION_PIN=

# YouTube has a universal APK; Music is arm64-v8a only.
YT_ARCH=universal
MUSIC_ARCH=arm64-v8a

# Sources tried on a cache miss, in order. apkmirror/apkpure use curl_cffi to get
# past Cloudflare; apkcombo/aptoide are curl fallbacks.
DL_SOURCES="apkmirror apkpure apkcombo aptoide"

STOCK_CACHE_TAG=stock-cache
