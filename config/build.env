# Build config, sourced by scripts/*.sh.

# morphe-cli is pinned (the patch format is coupled to the cli version).
MORPHE_CLI_VERSION=1.9.1
MORPHE_CLI_REPO=MorpheApp/morphe-cli

# Patch sources. anddea is my fork with the setting defaults baked in.
ANDDEA_REPO=pmaxhogan/revanced-patches
ANDDEA_CHANNEL=release
MORPHE_PATCHES_REPO=MorpheApp/morphe-patches
MORPHE_CHANNEL=release

YT_PACKAGE=com.google.android.youtube
MUSIC_PACKAGE=com.google.android.apps.youtube.music

# Piko is the morphe patch set for Twitter/X; it ships .mpp bundles like anddea.
# The X build stacks piko on top of x-shim (below). We consume a fork of piko that
# adds the "Hide verified users" patch (upstream piko has no such patch - it is an
# open, unimplemented request there). The fork is piko + that one patch; a rebuild
# picks up upstream piko changes, same tradeoff as the anddea fork. Floats to the
# fork's latest release.
PIKO_REPO=pmaxhogan/piko
PIKO_CHANNEL=release
X_PACKAGE=com.twitter.android

# x-shim (inotia00) is a mandatory compatibility layer for patching X 11.88+; its
# three patches must be applied together with piko. It lives on GitLab and is a
# ~35MB opaque binary that changes rarely, so unlike piko we PIN it to an exact
# version and verify its sha256 rather than floating.
XSHIM_GITLAB_PROJECT=inotia00/x-shim
XSHIM_VERSION=1.7.0
XSHIM_SHA256=dfbb1efacb8065b5b1b345f4478dac68282d13e5514caaf8e3e71f5d17ef9475

# Empty = newest patch-compatible version (morphe-cli list-versions). Set to pin.
YT_VERSION_PIN=
MUSIC_VERSION_PIN=
X_VERSION_PIN=

# YouTube has a universal APK; Music is arm64-v8a only.
YT_ARCH=universal
MUSIC_ARCH=arm64-v8a

# Sources tried on a cache miss, in order. apkmirror/apkpure use curl_cffi to get
# past Cloudflare; apkcombo/aptoide are curl fallbacks.
DL_SOURCES="apkmirror apkpure apkcombo aptoide"

# X has no universal single APK - it is distributed as a split APKM, which morphe
# patches directly. Only APKMirror serves the genuine APKM, so it is the sole
# source; the download gate verifies every split's signing cert (see download-apk.sh).
X_DL_SOURCES="apkmirror"
X_ARCH=universal

STOCK_CACHE_TAG=stock-cache
